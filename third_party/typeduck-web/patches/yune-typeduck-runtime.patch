+const SCHEMA_ID = "luna_pinyin";
+const DICTIONARY_ID = "luna_pinyin";
+
+// Yune runtime initialization
+const loadRime = (async () => {
+  try {
+    importScripts("yune-typeduck.js");
+    const module = await createYuneTypeduckModule({
+      printErr,
+      noInitialRun: true,
+      locateFile(path) {
+        return path;
+      },
+    });
+
+    if (module.IDBFS === undefined || module.IDBFS === null) {
+      throw new Error("Yune Emscripten module missing IDBFS runtime method");
+    }
+
+    mountTypeDuckPersistence(module.FS, module.IDBFS, {}, RIME_USER_DIR);
+
+    const assetsConfig: ExplicitTypeDuckAssets = {
+      defaultYaml: { type: "url", url: "schema/default.yaml" },
+      schemaYaml: { type: "url", url: `schema/${SCHEMA_ID}.schema.yaml` },
+      dictionaryYaml: { type: "url", url: `schema/${DICTIONARY_ID}.dict.yaml` },
+    };
+
+    const assets = await loadExplicitAssets(assetsConfig);
+    validateExplicitAssets(assets);
+    const extraSharedAssets = await loadExtraSharedAssets([
+      "default.custom.yaml",
+      "common.yaml",
+      "common.custom.yaml",
+      "include.yaml",
+      "template.yaml",
+      "jyut6ping3_scolar.schema.yaml",
+      "jyut6ping3_scolar.dict.yaml",
+      "loengfan.schema.yaml",
+      "loengfan.dict.yaml",
+      "cangjie3.schema.yaml",
+      "cangjie3.dict.yaml",
+      "cangjie5.schema.yaml",
+      "cangjie5.dict.yaml",
+      "opencc/hk2s.json",
+      "opencc/HKVariantsRev.ocd2",
+      "opencc/HKVariantsRevPhrases.ocd2",
+      "opencc/TSCharacters.ocd2",
+      "opencc/TSPhrases.ocd2",
+    ]);
+
+    await initYuneRuntime(
+      module,
+      module.FS,
+      {
+        sharedDataDir: RIME_SHARED_DIR,
+        userDataDir: RIME_USER_DIR,
+        schemaId: SCHEMA_ID,
+      },
+      assets,
+      DICTIONARY_ID,
+      extraSharedAssets,
+    );
+
+    loading = false;
+    dispatch("initialized", true);
+  } catch (error) {
+    console.error("Yune runtime initialization failed", error);
+    loading = false;
+    dispatch("initialized", false);
+    postMessage({
+      type: "error",
+      error: error instanceof Error ? `${error.name}: ${error.message}` : String(error),
+    });
+    throw error;
+  }
+})();
+
+function printErr(message: string): void {
+  if (process.env.NODE_ENV !== "production" || location.search === "?debug") {
+    const match = /^([IWEF])\S+ \S+ \S+ (.*)$/.exec(message);
+    if (match) {
+      console[({ I: "info", W: "warn", E: "error", F: "error" } as const)[match[1] as "I" | "W" | "E" | "F"]](`[${match[2]}`);
+    }
+    else {
+      console.error(message);
+    }
+  }
+}
+
+async function loadExtraSharedAssets(paths: string[]) {
+  return Promise.all(
+    paths.map(async (path) => {
+      const source: AssetSource = { type: "url", url: `schema/${path}` };
+      return {
+        path,
+        content: await loadAssetContent(source),
+      };
+    }),
+  );
+}
 
