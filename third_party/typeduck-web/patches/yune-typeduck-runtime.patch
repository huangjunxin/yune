+
+type BooleanRimePreference =
+  | "enableCompletion"
+  | "enableCorrection"
+  | "enableSentence"
+  | "enableLearning";
+
+const BOOLEAN_CUSTOMIZATION_KEYS: readonly {
+  preference: BooleanRimePreference;
+  keys: readonly string[];
