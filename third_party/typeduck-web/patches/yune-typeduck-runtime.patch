+import type { YuneStatusSnapshot } from "./types";
+
+function boolStatus(value: boolean, enabled: string, disabled: string) {
+	return `${value ? "true" : "false"} (${value ? enabled : disabled})`;
+}
+
+export default function YuneStatusStrip({ status }: { status?: YuneStatusSnapshot }) {
+	if (!status) {
+		return null;
+	}
+
+	const outputStandard = status.is_simplified ? "simplified" : "hk_traditional";
+
+	return <section className="my-3 rounded border border-base-300 bg-base-100 p-3 text-sm" data-yune-status>
+		<div className="mb-2 font-medium">引擎狀態 Engine status</div>
+		<p className="mb-2 text-base-content-300">顯示 runtime 回傳嘅完整 status 欄位。</p>
+		<div className="flex flex-wrap gap-2">
+			<span className="yd-tag gap-1.5" data-yune-status-schema-id-field>
+				<span className="font-mono">schema_id</span>
+				<span>{status.schema_id}</span>
+			</span>
+			<span className="yd-tag gap-1.5" data-yune-status-schema data-yune-status-schema-id={status.schema_id} data-yune-status-schema-name={status.schema_name}>
+				<span className="font-mono">schema_name</span>
+				<span>{status.schema_name || "(empty)"}</span>
+			</span>
+			<span className="yd-tag gap-1.5" data-yune-status-disabled={status.is_disabled}>
+				<span className="font-mono">is_disabled</span>
+				<span>{boolStatus(status.is_disabled, "disabled", "enabled")}</span>
+			</span>
+			<span className="yd-tag gap-1.5" data-yune-status-composing={status.is_composing}>
+				<span className="font-mono">is_composing</span>
+				<span>{boolStatus(status.is_composing, "composing", "idle")}</span>
+			</span>
+			<span className="yd-tag gap-1.5" data-yune-status-ascii={status.is_ascii_mode} data-yune-status-ascii-mode={status.is_ascii_mode}>
+				<span className="font-mono">is_ascii_mode</span>
+				<span>{boolStatus(status.is_ascii_mode, "ASCII", "Chinese")}</span>
+			</span>
+			<span className="yd-tag gap-1.5" data-yune-status-full-shape={status.is_full_shape}>
+				<span className="font-mono">is_full_shape</span>
+				<span>{boolStatus(status.is_full_shape, "full shape", "half shape")}</span>
+			</span>
+			<span className="yd-tag gap-1.5" data-yune-status-simplified={status.is_simplified} data-yune-status-output-standard={outputStandard}>
+				<span className="font-mono">is_simplified</span>
+				<span>{boolStatus(status.is_simplified, "simplified", "not simplified")}</span>
+			</span>
+			<span className="yd-tag gap-1.5" data-yune-status-traditional={status.is_traditional}>
+				<span className="font-mono">is_traditional</span>
+				<span>{boolStatus(status.is_traditional, "traditional", "off")}</span>
+			</span>
+			<span className="yd-tag gap-1.5" data-yune-status-ascii-punct={status.is_ascii_punct}>
+				<span className="font-mono">is_ascii_punct</span>
+				<span>{boolStatus(status.is_ascii_punct, "ASCII punct", "Chinese punct")}</span>
+			</span>
+		</div>
+	</section>;
