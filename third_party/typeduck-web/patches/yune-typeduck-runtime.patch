+import type { YuneInspectorDebug } from "./types";
+
+function formatScore(value: number | null | undefined) {
+	if (value === null || value === undefined) {
+		return "-";
+	}
+	return Number.isInteger(value) ? String(value) : value.toFixed(3);
+}
+
+export default function YuneInspector({ debug }: { debug?: YuneInspectorDebug }) {
+	return <section className="my-6 rounded-md border border-base-300 bg-base-100 p-4 text-sm" data-yune-inspector="panel">
+		<div className="mb-3 flex flex-wrap items-center justify-between gap-2">
+			<h2 className="text-base font-semibold">Yune inspector</h2>
+			<span className="rounded border border-base-300 px-2 py-1 font-geometric text-xs" data-yune-inspector-ai-state>
+				AI {debug?.ai_staging.state ?? "off"}
+			</span>
+		</div>
+		{debug
+			? <div className="grid gap-4 lg:grid-cols-2">
+				<div>
+					<h3 className="mb-2 font-semibold">Segments</h3>
+					<div className="flex flex-wrap gap-2" data-yune-inspector-segments>
+						{debug.segments.length
+							? debug.segments.map((segment, index) =>
+								<span key={`${segment.tag}-${index}`} className="rounded border border-base-300 px-2 py-1 font-geometric text-xs">
+									{segment.tag} {segment.start}-{segment.end}
+								</span>)
+							: debug.segment_tags.map(tag =>
+								<span key={tag} className="rounded border border-base-300 px-2 py-1 font-geometric text-xs">{tag}</span>)}
+					</div>
+				</div>
+				<div>
+					<h3 className="mb-2 font-semibold">Filters</h3>
+					<table className="w-full text-left text-xs" data-yune-inspector-filters>
+						<tbody>
+							{debug.filter_audit.length
+								? debug.filter_audit.map(record =>
+									<tr key={record.name}>
+										<td className="py-1 pr-2">{record.name}</td>
+										<td className="py-1 font-geometric">{`${record.before_count} -> ${record.after_count}`}</td>
+									</tr>)
+								: debug.filter_pipeline.map(name =>
+									<tr key={name}>
+										<td className="py-1 pr-2">{name}</td>
+										<td className="py-1 font-geometric">-</td>
+									</tr>)}
+						</tbody>
+					</table>
+				</div>
+				<div>
+					<h3 className="mb-2 font-semibold">Spelling algebra</h3>
+					{debug.spelling_algebra.map(algebra =>
+						<div key={`${algebra.translator}-${algebra.input}`} className="mb-3" data-yune-inspector-algebra>
+							<div className="font-geometric text-xs">{algebra.translator}</div>
+							<div className="mt-1 flex flex-wrap gap-1">
+								{algebra.expanded_codes.slice(0, 10).map(code =>
+									<span key={code} className="rounded bg-base-200 px-2 py-1 font-geometric text-xs">{code}</span>)}
+							</div>
+						</div>)}
+				</div>
+				<div>
+					<h3 className="mb-2 font-semibold">Prediction</h3>
+					<table className="w-full text-left text-xs" data-yune-inspector-prediction>
+						<thead>
+							<tr>
+								<th className="py-1 pr-2">Source</th>
+								<th className="py-1 pr-2">Text</th>
+								<th className="py-1">Quality</th>
+							</tr>
+						</thead>
+						<tbody>
+							{debug.prediction.candidates.slice(0, 8).map(candidate =>
+								<tr key={`${candidate.index}-${candidate.text}`}>
+									<td className="py-1 pr-2" data-yune-inspector-source>{candidate.source}</td>
+									<td className="py-1 pr-2">{candidate.text}</td>
+									<td className="py-1 font-geometric">{formatScore(candidate.quality)}</td>
+								</tr>)}
+						</tbody>
+					</table>
+				</div>
+			</div>
+			: <div className="text-base-content-300" data-yune-inspector-empty>No inspector data</div>}
+	</section>;
+}
