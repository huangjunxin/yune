diff --git a/src/SchemaSwitcher.tsx b/src/SchemaSwitcher.tsx
new file mode 100644
index 0000000..dd69452
--- /dev/null
+++ b/src/SchemaSwitcher.tsx
@@ -0,0 +1,44 @@
+import { SCHEMA_OPTIONS } from "./consts";
+import { Segment } from "./Inputs";
+
+import type { RimeSchemaId } from "./types";
+import type { Dispatch, SetStateAction } from "react";
+
+export default function SchemaSwitcher({
+	activeSchema,
+	setActiveSchema,
+	compact = false,
+}: {
+	activeSchema: RimeSchemaId;
+	setActiveSchema: Dispatch<SetStateAction<RimeSchemaId>>;
+	compact?: boolean;
+}) {
+	const controls = <div className="yd-segment-group flex-wrap" role="radiogroup" aria-label="方案 Schema">
+		{SCHEMA_OPTIONS.map(schema =>
+			<Segment
+				key={schema.id}
+				name="yuneSchema"
+				label={schema.schemaName}
+				state={activeSchema}
+				setState={setActiveSchema}
+				value={schema.id} />
+		)}
+	</div>;
+	const reverseLookup = <p className={compact ? "mt-1 text-xs text-base-content-300" : "mt-2 text-sm text-base-content-300"}>
+		{SCHEMA_OPTIONS.find(schema => schema.id === activeSchema)?.reverseLookup}
+	</p>;
+
+	if (compact) {
+		return <div className="yd-top-field yd-schema-switcher-compact" data-yune-schema-switcher>
+			<span className="yd-top-label">方案 Schema</span>
+			{controls}
+			{reverseLookup}
+		</div>;
+	}
+
+	return <fieldset className="my-4" data-yune-schema-switcher>
+		<legend className="mb-2 font-semibold">方案 Schema</legend>
+		{controls}
+		{reverseLookup}
+	</fieldset>;
+}
